# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────
# Local dev (SQLite — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./immigration_ai.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/immigration_ai

# ── Redis / Celery (only needed for background training jobs) ─────
REDIS_URL=redis://localhost:6379/0

# ── ML model ──────────────────────────────────────────────────────
BASE_MODEL=google/flan-t5-base
ADAPTER_PATH=backend/models/lora_adapter
ONNX_PATH=backend/models/onnx
USE_ONNX=false

# ── MLflow experiment tracking ────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Generation settings ───────────────────────────────────────────
MAX_NEW_TOKENS=350
NUM_BEAMS=4

# ── Debug ─────────────────────────────────────────────────────────
DEBUG=false
